<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- International suggest -->
    <route url="/v1/international/suggest/:context/:term" method="GET">
        <service class="Codebrainbv\PostcodeCheckout\Api\Validation" method="getAddressAutocomplete"/>
        <resources>
           <resource ref="anonymous" />
        </resources>
    </route>

    <!-- International details -->
    <route url="/v1/international/details/:context" method="GET">
        <service class="Codebrainbv\PostcodeCheckout\Api\Validation" method="getAddressDetails"/>
        <resources>
           <resource ref="anonymous" />
        </resources>
    </route>

    <!-- National endpoint CSP whitelist -->
    <route url="/v1/national/address/:zipCode/:houseNumber" method="GET">
        <service class="Codebrainbv\PostcodeCheckout\Api\Validation" method="getNationalAddress"/>
        <resources>
           <resource ref="anonymous" />
        </resources>
    </route>
</routes>
