<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- International suggest -->
    <route url="/V1/codebrainbv_postcodecheckout/international/suggest/:context/:term" method="GET">
        <service class="Codebrainbv\PostcodeCheckout\Api\ValidationInterface" method="getAddressAutocomplete"/>
        <resources>
           <resource ref="anonymous" />
        </resources>
    </route>

    <!-- International details -->
    <route url="/V1/codebrainbv_postcodecheckout/international/details/:context" method="GET">
        <service class="Codebrainbv\PostcodeCheckout\Api\ValidationInterface" method="getAddressDetails"/>
        <resources>
           <resource ref="anonymous" />
        </resources>
    </route>

    <!-- National endpoint -->
    <route url="/V1/codebrainbv_postcodecheckout/national/address/:zipCode/:houseNumber" method="GET">
        <service class="Codebrainbv\PostcodeCheckout\Api\ValidationInterface" method="getNationalAddress"/>
        <resources>
           <resource ref="anonymous" />
        </resources>
    </route>
</routes>
