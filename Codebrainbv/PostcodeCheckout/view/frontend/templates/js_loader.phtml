<?php
/** @var \Codebrainbv\PostcodeCheckout\Block\Config $block */
$configuredProvider = $block->getConfiguredProvider();
$jsFiles = $block->getJsFilesForProvider();
?>

<div style="background:red;color:white;padding:10px;">
    JS Loader Template Loaded!
    <br>
    Block class: <?= get_class($block) ?>
</div>



<!-- 
    Postcode Checkout Dynamic Loader
    Supports both Hyvä (Alpine.js) and RequireJS
-->

<script>
    (function() {
        // Detect if RequireJS is present (Luma, default Magento)
        var hasRequireJS = (typeof require === 'function');

        if (hasRequireJS) {
            console.log('RequireJS detected - loading scripts via RequireJS');

            // RequireJS array generated by PHP
            require(<?= json_encode($jsFiles) ?>, function() {
                console.log('RequireJS scripts loaded for provider: <?= $provider ?>');
                for (var i = 0; i < arguments.length; i++) {
                    if (typeof arguments[i].init === 'function') {
                        arguments[i].init();
                    }
                }
            });

        } else {
            console.log('Hyvä detected - loading scripts via <script> tags');

            // Fallback: Directly inject <script> tags for Hyvä
            var head = document.head || document.getElementsByTagName('head')[0];
            var files = <?= json_encode($jsFiles) ?>;

            files.forEach(function(path) {
                var script = document.createElement('script');
                script.src = '<?= $block->getViewFileUrl('') ?>' + path + '.js';
                head.appendChild(script);
            });
        }
    })();
</script>

