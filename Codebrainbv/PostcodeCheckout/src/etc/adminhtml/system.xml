<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="checkout">
            <group id="postcodecheckout" translate="label" type="text" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>PostcodeCheckout</label>
                <field id="api_key" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Postcode API Key</label>
                    <comment>Enter the API key we provided</comment>
                </field>
            </group>
        </section>
    </system>
</config>
