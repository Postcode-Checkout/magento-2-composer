<script>
require(['domReady!'], function () {
    var cfg = window.pcm2_config || {};
    var provider = cfg.configured_provider || '';

    if (['pro6pp', 'postcodenl', 'postcodeapi'].indexOf(provider) !== -1) {
        require(['Codebrainbv_PostcodeCheckout/js/national/postcodecheckoutnational']);
    } else if (provider === 'postcodenlext') {
        require([
            'css!Codebrainbv_PostcodeCheckout/css/autocompleteaddress',
            'autocompleteaddress',
            'Codebrainbv_PostcodeCheckout/js/international/postcodecheckoutinternational'
        ]);
    } else {
        console.log('PCM2: no provider found');
    }
});
</script>
